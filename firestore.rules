rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // Employees — allow get by ID (needed for login) but not list (prevents bulk dump)
    // Allow create for self-registration; no client-side updates or deletes
    match /employees/{employeeId} {
      allow get:    if true;
      allow list:   if false;
      allow create: if true;
      allow update, delete: if false;
    }

    // Classrooms — auth enforced client-side via session; open read/write here
    match /classrooms/{classroomId} {
      allow read, write: if true;

      match /{subcollection}/{docId} {
        allow read, write: if true;
      }
    }
  }
}
