rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // Teachers — each teacher can only read/write their own profile
    match /teachers/{userId} {
      allow read, write: if request.auth != null && request.auth.uid == userId;
    }

    // Classrooms — owned by a single teacher
    match /classrooms/{classroomId} {

      function isOwner() {
        return request.auth != null &&
               resource.data.teacherId == request.auth.uid;
      }

      function isNewOwner() {
        return request.auth != null &&
               request.resource.data.teacherId == request.auth.uid;
      }

      allow read:          if isOwner();
      allow create:        if isNewOwner();
      allow update, delete: if isOwner();

      // Subcollections (log, status, roster) inherit classroom ownership
      match /{subcollection}/{docId} {
        allow read, write: if request.auth != null &&
          get(/databases/$(database)/documents/classrooms/$(classroomId))
            .data.teacherId == request.auth.uid;
      }
    }
  }
}
